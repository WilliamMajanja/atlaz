# ── Atlaz — Land Intelligence & Business Operations ──
# Copy this file to .env.local and fill in your values.
# cp .env.example .env.local

# ── App ──
NEXT_PUBLIC_APP_NAME=Atlaz
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TAGLINE=Land Intelligence & Business Operations

# ── Database (Prisma / SQLite — optional, demo works without a DB) ──
# DATABASE_URL="file:./dev.db"

# ── Ollama (local AI — optional; fallback to local generation if unavailable) ──
# Ollama endpoint. Defaults to http://localhost:11434 if not set.
# OLLAMA_ENDPOINT=http://localhost:11434
# Model used for speculation briefs and anomaly analysis.
# OLLAMA_MODEL=llama3.2

# ── Mapbox (optional — fallback to OpenStreetMap tiles) ──
# NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Map Defaults ──
# Default map center (Zanzibar)
NEXT_PUBLIC_DEFAULT_LAT=-6.1659
NEXT_PUBLIC_DEFAULT_LNG=39.2026
NEXT_PUBLIC_DEFAULT_ZOOM=11
